# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Anthropic
ANTHROPIC_API_KEY=sk-ant-your-key

# Polygon (primary market data)
POLYGON_API_KEY=your_polygon_key

# Resend (transactional email)
RESEND_API_KEY=re_your_key

# Finnhub (optional — backup data source, endpoints fail gracefully if missing)
FINNHUB_API_KEY=

# Financial Modeling Prep (optional — fundamentals data)
FMP_API_KEY=

# Stripe (add later)
STRIPE_SECRET_KEY=sk_test_your_key
STRIPE_WEBHOOK_SECRET=whsec_your_secret

# SnapTrade (optional — broker sync scaffold, not yet wired up)
# Leave blank to keep manual portfolio entry only.
SNAPTRADE_CLIENT_ID=
SNAPTRADE_CONSUMER_KEY=

# App
FRONTEND_URL=http://localhost:5173
PORT=3001
NODE_ENV=development

# Admin (optional — protects /api/health?verbose=true and /api/admin/insights)
ADMIN_SECRET=

# Founder admin emails — comma-separated list of emails that get admin access
# (Founder Dashboard, founder digest email recipient). Without this, admin
# routes return 403 and the Monday founder-digest job has no recipient.
FOUNDER_EMAILS=

# Deploy flags
# Set BETA_ALLOWLIST_OPEN=true to disable the beta_allowlist signup gate (post-public-launch)
BETA_ALLOWLIST_OPEN=false
# Set JOBS_SEPARATE_PROCESS=true on the API service when jobs runs as its own service
# (prevents the alert monitor from running in both processes)
JOBS_SEPARATE_PROCESS=false

# ── Frontend build (set in Vercel, NOT in this backend env) ──────────────────
# The static frontend reads its API base URL at BUILD time from VITE_API_URL.
# Set it in the Vercel project's Environment Variables to your deployed backend
# URL (for example https://outpost-api.up.railway.app). Vite bakes it into the
# bundle at build, so it does NOT belong in the backend env. See DEPLOY.md.
# VITE_API_URL=https://your-backend.up.railway.app
